{
  "name": "@app/native",
  "description": "Primate native template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/native^... build",
    "build": "bunx --bun primate build --target=desktop",
    "build:linux-x64": "bunx --bun primate build --target=linux-x64",
    "build:darwin-x64": "bunx --bun primate build --target=darwin-x64",
    "build:darwin-arm64": "bunx --bun primate build --target=darwin-arm64",
    "build:windows-x64": "bunx --bun primate build --target=windows-x64"
  },
  "dependencies": {
    "@primate/html": "workspace:^",
    "@primate/native": "workspace:^",
    "primate": "workspace:^"
  }
}
