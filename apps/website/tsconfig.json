{
  "extends": "primate/tsconfig",
  "compilerOptions": {
    "baseUrl": "${configDir}",
    "paths": {
      "@/*": [
        "*"
      ]
    },
    "types": [
      "primate"
    ]
  },
  "include": [
    "${configDir}/client",
    "${configDir}/config",
    "${configDir}/routes",
    "${configDir}/views",
    "${configDir}/components",
    "${configDir}/stores",
    "${configDir}/test",
    "${configDir}/templates",
    "${configDir}/static"
  ],
  "exclude": [
    "node_modules"
  ]
}
