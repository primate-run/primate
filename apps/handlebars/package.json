{
  "name": "@app/handlebars",
  "description": "Primate Handlebars template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/handlebars^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/handlebars": "workspace:^",
    "handlebars": "^4.7.9",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
