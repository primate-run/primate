import route from "#route/route-client/path/[name]";

<let/result=null/>

<const/send=async () => {
  const response = await route.post({ path: { name: "hello" } });
  result = await response.json();
}/>

<button onClick=send>Send</button>

<if=result !== null>
  <span id="result">${JSON.stringify(result)}</span>
</if>
