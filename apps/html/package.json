{
  "name": "@app/html",
  "description": "Primate HTML template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/html^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/html": "workspace:^",
    "pema": "workspace:^",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
