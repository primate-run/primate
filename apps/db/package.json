{
  "name": "@app/db",
  "description": "Primate database template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/db^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "@primate/html": "workspace:^",
    "@primate/sqlite": "workspace:^",
    "@rcompat/assert": "^0.14.0",
    "@rcompat/type": "^0.18.0",
    "pema": "workspace:^",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
