{
  "name": "@app/ruby",
  "description": "Primate Ruby template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/ruby^... build",
    "build": "primate build",
    "serve": "primate serve",
    "pretest": "bundle install",
    "test": "proby",
    "test:backend": "npm run test",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/ruby": "workspace:^",
    "@primate/svelte": "workspace:^",
    "@ruby/head-wasm-wasi": "2.9.3-2.9.4",
    "pema": "workspace:^",
    "primate": "workspace:^",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
