{
  "name": "@primate/app/python",
  "description": "Primate Python template",
  "type": "module",
  "scripts": {
    "start": "npx primate",
    "build": "npx primate build",
    "serve": "npx primate serve",
    "pretest": "uv venv --clear && uv pip install --refresh -r requirements.txt",
    "test": "npx proby",
    "test:backend": "npm run test",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/html": "workspace:^",
    "@primate/python": "workspace:^",
    "@primate/svelte": "workspace:^",
    "pema": "workspace:^",
    "primate": "workspace:^",
    "pyodide": "314.0.0",
    "svelte": "^5.56.0"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
