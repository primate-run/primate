{
  "name": "@app/routing",
  "description": "Primate routing template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/routing^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@rcompat/http": "^0.31.0",
    "pema": "workspace:^",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
