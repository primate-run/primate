{
  "name": "@primate/app/ts",
  "description": "Primate TypeScript template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/ts^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:backend": "npm run test",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/svelte": "workspace:^",
    "@rcompat/fs": "^0.35.1",
    "@rcompat/http": "^0.31.0",
    "pema": "workspace:^",
    "primate": "workspace:^",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
