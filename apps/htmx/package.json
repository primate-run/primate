{
  "name": "@app/htmx",
  "description": "Primate HTMX template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/htmx^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/htmx": "workspace:^",
    "handlebars": "^4.7.9",
    "htmx-ext-client-side-templates": "^2.0.2",
    "htmx.org": "^2.0.10",
    "mustache": "^4.2.0",
    "nunjucks": "^3.2.4",
    "pema": "workspace:^",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
