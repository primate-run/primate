{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "${configDir}",
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true,
    "exactOptionalPropertyTypes": true,
    "allowImportingTsExtensions": true,
    "types": [
      "primate"
    ],
    "customConditions": [
      "@primate/source"
    ],
    "paths": {
      "#view/*": [
        "views/*"
      ],
      "#component/*": [
        "components/*"
      ],
      "#store/*": [
        "stores/*"
      ],
      "#locale/*": [
        "locales/*"
      ],
      "#config/*": [
        "config/*"
      ],
      "#static/*": [
        "static/*"
      ],
      "#app": [
        "config/app"
      ],
      "#session": [
        "config/session"
      ],
      "#i18n": [
        "config/i18n"
      ]
    }
  },
  "include": [
    "${configDir}/config",
    "${configDir}/routes",
    "${configDir}/views",
    "${configDir}/stores",
    "${configDir}/test",
    "${configDir}/static"
  ],
  "exclude": [
    "node_modules"
  ]
}
