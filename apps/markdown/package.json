{
  "name": "@app/markdown",
  "description": "Primate Markdown template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/markdown^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test": "proby",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@primate/markdown": "workspace:^",
    "marked": "^18.0.5",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  }
}
