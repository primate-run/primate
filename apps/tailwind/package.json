{
  "name": "@app/tailwind",
  "description": "Primate Tailwind template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/tailwind^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test:deno": "deno run -A npm:primate test",
    "test:bun": "bun x --bun primate test"
  },
  "dependencies": {
    "@primate/react": "workspace:^",
    "@primate/tailwind": "workspace:^",
    "pema": "workspace:^",
    "primate": "workspace:^",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  }
}
