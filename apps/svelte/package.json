{
  "name": "@app/svelte",
  "description": "Primate Svelte template",
  "type": "module",
  "scripts": {
    "start": "primate",
    "prebuild": "pnpm --dir ../.. -r --filter-prod @app/svelte^... build",
    "build": "primate build",
    "serve": "primate serve",
    "test:csr": "SSR=0 CSR=1 proby test/test.spec.ts",
    "test:ssr": "SSR=1 CSR=0 proby test/test.spec.ts",
    "test:hydrate": "SSR=1 CSR=1 proby test/test.spec.ts",
    "test": "npm run test:ssr && npm run test:csr && npm run test:hydrate",
    "test:frontend": "npm run test",
    "test:deno": "deno run -A npm:proby",
    "test:bun": "bunx --bun proby"
  },
  "dependencies": {
    "@lucide/svelte": "^1.18.0",
    "@primate/sqlite": "workspace:^",
    "@primate/svelte": "workspace:^",
    "@rcompat/assert": "^0.14.0",
    "@rcompat/env": "^0.23.0",
    "bits-ui": "^2.18.1",
    "mode-watcher": "^1.1.0",
    "pema": "workspace:^",
    "primate": "workspace:^",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@primate/test": "workspace:^",
    "typescript": "^7.0.2"
  }
}
