{
  "name": "@primate/test",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/test"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf ./lib",
    "lint": "eslint ."
  },
  "dependencies": {
    "@rcompat/fs": "^0.26.0",
    "@rcompat/test": "^0.10.0",
    "happy-dom": "^20.8.4",
    "primate": "workspace:^"
  },
  "devDependencies": {
    "@rcompat/type": "^0.9.0"
  },
  "imports": {
    "#*": {
      "apekit": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    "./*": {
      "apekit": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    },
    ".": {
      "apekit": "./src/public/index.ts",
      "default": "./lib/public/index.js"
    }
  }
}
