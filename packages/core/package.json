{
  "name": "@primate/core",
  "version": "0.7.0-pre",
  "description": "The universal web framework",
  "homepage": "https://primate.run",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/core"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "/lib/private/defaults/*.html",
    "!/**/*.spec.*"
  ],
  "scripts": {
    "build": "npm run clean && tsc && cp -a src/private/defaults lib/private",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "test": "npx proby"
  },
  "dependencies": {
    "@rcompat/assert": "^0.10.0",
    "@rcompat/cli": "^0.20.0",
    "@rcompat/crypto": "^0.18.0",
    "@rcompat/dict": "^0.7.1",
    "@rcompat/env": "^0.19.0",
    "@rcompat/error": "^0.5.0",
    "@rcompat/fn": "^0.7.0",
    "@rcompat/fs": "^0.30.0",
    "@rcompat/http": "^0.27.1",
    "@rcompat/io": "^0.7.0",
    "@rcompat/is": "^0.8.0",
    "@rcompat/kv": "^0.10.0",
    "@rcompat/runtime": "^0.13.0",
    "@rcompat/string": "^0.18.0",
    "@rcompat/type": "^0.14.0",
    "esbuild": "^0.28.0",
    "pema": "workspace:^"
  },
  "imports": {
    "#i18n/index": {
      "@primate/source": "./src/private/i18n/index/client.ts",
      "browser": "./lib/private/i18n/index/client.js",
      "default": "./lib/private/i18n/index/server.js"
    },
    "#*": {
      "@primate/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    "./AppFacade": {
      "@primate/source": "./src/public/AppFacade.ts",
      "browser": "./lib/private/app/Facade.browser.js",
      "default": "./lib/public/AppFacade.js"
    },
    "./*": {
      "@primate/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    },
    ".": {
      "@primate/source": "./src/public/index.ts",
      "default": "./lib/public/index.js"
    }
  }
}
