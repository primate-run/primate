{
  "name": "@primate/react",
  "version": "0.21.0-pre",
  "description": "React for Primate",
  "homepage": "https://primate.run/docs/frontend/react",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/react"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc && cp src/types/index.d.ts lib && cp src/types/app.d.ts lib",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rcompat/type": "^0.18.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "@rcompat/runtime": "^0.17.0"
  },
  "peerDependencies": {
    "@types/react": "19",
    "@types/react-dom": "19",
    "primate": "workspace:^",
    "react": "19",
    "react-dom": "19"
  },
  "imports": {
    "#request/default": {
      "@primate/source": "./src/private/request/default.tsx",
      "default": "./lib/private/request/default.js"
    },
    "#*": {
      "@primate/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "browser": {
        "@primate/source": "./src/public/browser.ts",
        "default": "./lib/public/browser.js"
      },
      "@primate/runtime": "./src/public/runtime.ts",
      "@primate/source": "./src/public/default.ts",
      "runtime": "./lib/public/runtime.js",
      "default": "./lib/public/default.js"
    },
    "./*": {
      "@primate/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    },
    "./app": {
      "browser": {
        "@primate/source": "./src/public/app/browser.ts",
        "default": "./lib/public/app/browser.js"
      },
      "@primate/source": "./src/public/app/default.ts",
      "default": "./lib/public/app/default.js"
    },
    "./Head": {
      "browser": {
        "@primate/source": "./src/public/Head/browser.ts",
        "default": "./lib/public/Head/browser.js"
      },
      "@primate/source": "./src/public/Head/default.ts",
      "default": "./lib/public/Head/default.js"
    }
  }
}
