{
  "name": "@primate/svelte",
  "version": "0.26.0-pre",
  "description": "Svelte for Primate",
  "homepage": "https://primate.run/docs/frontend/svelte",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/svelte"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsgo && cp src/types/app.d.ts lib && cp src/types/index.d.ts lib",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "@rcompat/fs": "^0.33.2",
    "esbuild": "^0.28.0"
  },
  "devDependencies": {
    "@rcompat/type": "^0.17.0"
  },
  "peerDependencies": {
    "primate": "workspace:^",
    "svelte": "5"
  },
  "imports": {
    "#*": {
      "@primate/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "browser": {
        "@primate/source": "./src/public/browser.ts",
        "default": "./lib/public/browser.js"
      },
      "@primate/runtime": "./src/public/runtime.ts",
      "@primate/source": "./src/public/default.ts",
      "runtime": "./lib/public/runtime.js",
      "default": "./lib/public/default.js"
    },
    "./i18n": {
      "@primate/source": "./src/public/i18n.ts",
      "default": "./lib/public/i18n.js"
    },
    "./*": {
      "@primate/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    }
  }
}
