{
  "name": "@primate/svelte",
  "version": "0.23.0-pre",
  "description": "Svelte for Primate",
  "homepage": "https://primate.run/docs/frontend/svelte",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/svelte"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc && cp src/types/{app,index}.d.ts lib",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "test": "npm run build && npx proby"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "esbuild": "^0.27.4"
  },
  "devDependencies": {
    "@primate/test": "workspace:^",
    "@rcompat/type": "^0.9.0"
  },
  "peerDependencies": {
    "primate": "workspace:^",
    "svelte": "5"
  },
  "imports": {
    "#*": {
      "apekit": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "browser": "./lib/public/browser.js",
      "runtime": "./lib/public/runtime.js",
      "default": "./lib/public/default.js"
    },
    "./*": {
      "apekit": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    }
  }
}
