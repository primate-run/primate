{
  "name": "@primate/mysql",
  "version": "0.7.0-pre",
  "description": "MySQL databases for Primate",
  "homepage": "https://primate.run/docs/database/mysql",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/mysql"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "mysql": "scripts/mysql.sh",
    "mariadb": "scripts/mariadb.sh",
    "test:mysql": "npm run mysql && npx proby",
    "test:mariadb": "npm run mariadb && npx proby",
    "test": "npm run test:mysql"
  },
  "devDependencies": {
    "@rcompat/type": "^0.15.1"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "@rcompat/assert": "^0.11.0",
    "@rcompat/is": "^0.9.0",
    "mysql2": "^3.20.0",
    "pema": "workspace:"
  },
  "peerDependencies": {
    "primate": "workspace:^"
  },
  "imports": {
    "#*": {
      "@primate/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "@primate/source": "./src/public/index.ts",
      "default": "./lib/public/index.js"
    }
  }
}
