{
  "name": "@primate/htmx",
  "version": "0.25.0-pre",
  "description": "HTMX for Primate",
  "homepage": "https://primate.run/docs/frontend/htmx",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/htmx"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "test": "npx proby"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "@primate/html": "workspace:^",
    "@rcompat/assert": "^0.11.0",
    "@rcompat/error": "^0.6.2",
    "@rcompat/fs": "^0.31.0",
    "@rcompat/is": "^0.9.0",
    "@rcompat/runtime": "^0.14.4",
    "@rcompat/string": "^0.19.0",
    "pema": "workspace:^"
  },
  "devDependencies": {
    "@primate/test": "workspace:^"
  },
  "peerDependencies": {
    "handlebars": "4",
    "htmx-ext-client-side-templates": "2",
    "htmx.org": "2",
    "mustache": "4",
    "nunjucks": "3",
    "primate": "workspace:^"
  },
  "peerDependenciesMeta": {
    "htmx-ext-client-side-templates": {
      "optional": true
    },
    "mustache": {
      "optional": true
    },
    "handlebars": {
      "optional": true
    },
    "nunjucks": {
      "optional": true
    }
  },
  "imports": {
    "#*": {
      "@primate/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    },
    "#pkg-json": "./package.json"
  },
  "exports": {
    ".": {
      "@primate/source": "./src/public/default.ts",
      "browser": "./lib/public/browser.js",
      "runtime": "./lib/public/runtime.js",
      "default": "./lib/public/default.js"
    },
    "./*": {
      "@primate/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    }
  }
}
