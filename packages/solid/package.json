{
  "name": "@primate/solid",
  "version": "0.10.0-pre",
  "description": "SolidJS for Primate",
  "homepage": "https://primate.run/docs/frontend/solid",
  "bugs": "https://github.com/primate-run/primate/issues",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/solid"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc && cp src/types/{app,index}.d.ts lib",
    "postbuild": "node scripts/compile-jsx.js",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "test": "npx proby"
  },
  "devDependencies": {
    "@primate/test": "workspace:^",
    "@rcompat/type": "^0.14.0",
    "@types/babel__core": "^7.20.5"
  },
  "dependencies": {
    "@babel/core": "^7.28.6",
    "@primate/core": "workspace:^",
    "@rcompat/fs": "^0.30.0",
    "@rcompat/runtime": "^0.13.0",
    "babel-preset-solid": "^1.9.12"
  },
  "peerDependencies": {
    "primate": "workspace:^",
    "solid-js": "1"
  },
  "imports": {
    "#*": {
      "@primate/source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    },
    "#HeadImpl": {
      "@primate/source": "./src/private/Head/default.ts",
      "browser": "./lib/private/Head/browser.js",
      "default": "./lib/private/Head/default.js"
    }
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "@primate/source": "./src/public/default.ts",
      "browser": "./lib/public/browser.js",
      "runtime": "./lib/public/runtime.js",
      "default": "./lib/public/default.js"
    },
    "./*": {
      "@primate/source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    },
    "./i18n/Bridge": {
      "@primate/source": "./src/public/i18n/Bridge/default.ts",
      "browser": "./lib/public/i18n/Bridge/browser.js",
      "default": "./lib/public/i18n/Bridge/default.js"
    }
  }
}
