{
  "name": "@primate/html",
  "version": "0.20.0-pre",
  "description": "HTML for Primate",
  "homepage": "https://primate.run/docs/frontend/html",
  "bugs": "https://github.com/primate-run/primate/issues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primate-run/primate",
    "directory": "packages/html"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts",
    "!/**/*.spec.*"
  ],
  "scripts": {
    "build": "npm run clean && tsgo",
    "clean": "rm -rf ./lib",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@primate/core": "workspace:^",
    "@rcompat/html": "^0.16.0",
    "@rcompat/string": "^0.21.0",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@rcompat/type": "^0.17.0"
  },
  "imports": {
    "#*": {
      "source": "./src/private/*.ts",
      "default": "./lib/private/*.js"
    }
  },
  "exports": {
    ".": {
      "browser": {
        "@primate/source": "./src/public/browser.ts",
        "default": "./lib/public/browser.js"
      },
      "@primate/runtime": "./src/public/runtime.ts",
      "@primate/source": "./src/public/default.ts",
      "runtime": "./lib/public/runtime.js",
      "default": "./lib/public/default.js"
    },
    "./*": {
      "source": "./src/public/*.ts",
      "default": "./lib/public/*.js"
    }
  }
}
